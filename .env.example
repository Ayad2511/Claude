# =============================================
# ANTHROPIC (Claude AI)
# Haal je key op via: https://console.anthropic.com
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# OPENAI (Whisper transcriptie)
# Haal je key op via: https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=sk-...

# =============================================
# GO HIGH LEVEL
# Haal je API key op via: Instellingen > Integraties > API Key
# =============================================
GHL_API_KEY=eyJ...
GHL_LOCATION_ID=abc123          # Je locatie/subaccount ID
GHL_PIPELINE_ID=def456          # De pipeline waar je leads in staan

# =============================================
# PIPELINE STAGE IDS
# Ga naar je GHL Pipeline > kopieer de Stage IDs uit de URL of via de API:
# GET https://services.leadconnectorhq.com/opportunities/pipelines
# =============================================
STAGE_GEEN_FIT_GEEN_INTERESSE=stage_id_hier
STAGE_ICP_GEEN_FIT=stage_id_hier
STAGE_ICP_GEEN_INTERESSE=stage_id_hier
STAGE_ICP_NIET_WARM=stage_id_hier
STAGE_ICP_GEPLAND=stage_id_hier

# Niet opgenomen follow-up stages
STAGE_DAG1_NIET_OPGENOMEN=stage_id_hier
STAGE_DAG2_NIET_OPGENOMEN=stage_id_hier
STAGE_DAG3_NIET_OPGENOMEN=stage_id_hier
STAGE_NAGEBELD_NIET_OPGENOMEN=stage_id_hier

# =============================================
# SLACK DAGRAPPORT
# Maak een Slack Incoming Webhook aan:
# Slack > Apps > Incoming WebHooks > Add to Slack
# =============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DAILY_REPORT_TIME=18:00    # Tijdstip dagrapport (HH:MM, 24-uurs formaat)
DAILY_ADVANCE_TIME=08:00   # Tijdstip doorschuiven niet-opgenomen leads

# =============================================
# WEBHOOK BEVEILIGING (optioneel)
# Laat leeg als je geen signature-verificatie wilt
# =============================================
WEBHOOK_SECRET=

# =============================================
# OUTREACH SYSTEEM — GMAIL SMTP
# Vereist: 2-stapsverificatie aan op Google account
# Stap 1: Google Account → Beveiliging → 2-stapsverificatie → aan
# Stap 2: Google Account → Beveiliging → App-wachtwoorden → kies "Mail"
# Kopieer het gegenereerde 16-cijferige wachtwoord hieronder
# =============================================
GMAIL_ADDRESS=jouw@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SENDER_NAME=Jouw Naam

# =============================================
# OUTREACH SYSTEEM — LOOM VIDEO
# Vul je Loom video URL in (bijv. https://www.loom.com/share/abc123)
# Voor de thumbnail: open je Loom video → rechtsclick op thumbnail → "Afbeelding URL kopiëren"
# Of gebruik: https://cdn.loom.com/sessions/thumbnails/LOOM_ID/thumbnail.jpg
# =============================================
LOOM_VIDEO_URL=https://www.loom.com/share/jouw-video-id
LOOM_THUMBNAIL_URL=https://cdn.loom.com/sessions/thumbnails/jouw-video-id/thumbnail.jpg

# =============================================
# OUTREACH SYSTEEM — LINKEDIN (optioneel)
# li_at cookie: open LinkedIn in browser → DevTools (F12) →
# Application → Cookies → linkedin.com → kopieer waarde van "li_at"
# =============================================
LINKEDIN_LI_AT=

# =============================================
# OUTREACH SYSTEEM — PLANNING & LIMIETEN
# Start de eerste week met OUTREACH_DAILY_MAX=5 voor warm-up
# Verhoog naar 10 in week 2, dan 15 vanaf week 3
# =============================================
OUTREACH_DAILY_MAX=5
OUTREACH_RUN_TIME=09:00
SCRAPE_RUN_TIME=07:00
SCRAPE_MAX_LEADS_PER_RUN=30

# Dry-run: emails worden samengesteld maar NIET verstuurd (true/false)
# Zet op true voor testen, false voor live gebruik
OUTREACH_DRY_RUN=true

# SQLite database locatie (standaard: outreach.db in project root)
DB_PATH=outreach.db
