# =============================================
# ANTHROPIC (Claude AI)
# Haal je key op via: https://console.anthropic.com
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# OPENAI (Whisper transcriptie)
# Haal je key op via: https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=sk-...

# =============================================
# GO HIGH LEVEL
# Haal je API key op via: Instellingen > Integraties > API Key
# =============================================
GHL_API_KEY=eyJ...
GHL_LOCATION_ID=abc123          # Je locatie/subaccount ID
GHL_PIPELINE_ID=def456          # De pipeline waar je leads in staan

# =============================================
# PIPELINE STAGE IDS
# Ga naar je GHL Pipeline > kopieer de Stage IDs uit de URL of via de API:
# GET https://services.leadconnectorhq.com/opportunities/pipelines
# =============================================
STAGE_GEEN_FIT_GEEN_INTERESSE=stage_id_hier
STAGE_ICP_GEEN_FIT=stage_id_hier
STAGE_ICP_GEEN_INTERESSE=stage_id_hier
STAGE_ICP_NIET_WARM=stage_id_hier
STAGE_ICP_GEPLAND=stage_id_hier

# =============================================
# WEBHOOK BEVEILIGING (optioneel)
# Laat leeg als je geen signature-verificatie wilt
# =============================================
WEBHOOK_SECRET=
